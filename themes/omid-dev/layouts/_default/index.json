{{- $.Scratch.Add "index" slice -}}
{{- range site.RegularPages -}}
    {{- if and (not .Params.searchHidden) (ne .Layout `archives`) (ne .Layout `search`) }}
    {{- $.Scratch.Add "index" (dict "title" (.Title | plainify | htmlUnescape) "permalink" .Permalink "summary" (.Summary | plainify | htmlUnescape) "tags" .Params.tags "categories" .Params.categories "date" .Params.Date "section" .Section "readingTime" .ReadingTime) -}}
    {{- end }}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
