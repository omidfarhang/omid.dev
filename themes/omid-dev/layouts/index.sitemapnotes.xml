{{ partial "sitemap/xml-header.html" . }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml">
{{- $notesSection := site.Params.notesSection | default "notes" -}}
{{- with site.GetPage "section" $notesSection -}}
  {{- partial "sitemap/url-entry.html" . -}}
{{- end -}}
{{- range where site.RegularPages "Section" $notesSection -}}
  {{- partial "sitemap/url-entry.html" . -}}
{{- end -}}
</urlset>
