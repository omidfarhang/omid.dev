{{ partial "sitemap/xml-header.html" . }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml">
{{- with site.Home -}}
  {{- partial "sitemap/url-entry.html" . -}}
{{- end -}}
{{- with site.GetPage "section" (site.Params.notesSection | default "notes") -}}
  {{- partial "sitemap/url-entry.html" . -}}
{{- end -}}
{{- range where site.RegularPages "Section" "" -}}
  {{- if not .Params.robotsNoIndex -}}
    {{- partial "sitemap/url-entry.html" . -}}
  {{- end -}}
{{- end -}}
</urlset>
