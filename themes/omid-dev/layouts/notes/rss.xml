{{- $authorEmail := "" }}
{{- with site.Params.author }}
  {{- if reflect.IsMap . }}
    {{- with .email }}{{ $authorEmail = . }}{{ end }}
  {{- end }}
{{- end }}

{{- $authorName := site.Params.author | default site.Title }}
{{- if reflect.IsMap site.Params.author }}
  {{- $authorName = site.Params.author.name | default site.Title }}
{{- end }}

{{- $pages := where .RegularPages "Section" (site.Params.notesSection | default "notes") }}
{{- $pages = $pages.ByDate.Reverse }}
{{- $limit := site.Config.Services.RSS.Limit }}
{{- if ge $limit 1 }}
{{- $pages = $pages | first $limit }}
{{- end }}

{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ i18n "notes" | default "Notes" }} · {{ site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ i18n "notes_rss_description" | default "Short notes and quick thoughts" }}</description>
    <generator>Hugo -- {{ hugo.Version }}</generator>
    <language>{{ site.Language.Locale }}</language>
    {{- with $authorEmail }}
    <managingEditor>{{ . }}{{ with $authorName }} ({{ . }}){{ end }}</managingEditor>
    <webMaster>{{ . }}{{ with $authorName }} ({{ . }}){{ end }}</webMaster>
    {{- end }}
    {{- if gt (len $pages) 0 }}
    <lastBuildDate>{{ (index $pages 0).Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    {{- end }}
    {{- with .OutputFormats.Get "RSS" }}
    {{ printf "<atom:link href=%q rel=\"self\" type=%q />" .Permalink .MediaType | safeHTML }}
    {{- end }}
    {{- range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .PublishDate.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      {{- with $authorEmail }}<author>{{ . }}{{ with $authorName }} ({{ . }}){{ end }}</author>{{ end }}
      <guid>{{ .Permalink }}</guid>
      <description>{{ .Content | plainify | truncate 280 | html }}</description>
    </item>
    {{- end }}
  </channel>
</rss>
